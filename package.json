{
  "name": "telegram-ai-v2",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:daemon": "bun --filter @tg/daemon dev",
    "cli": "bun run apps/cli/src/index.ts --",
    "dev:web": "bun --filter @tg/web dev",
    "dev:app": "bun --filter @tg/app dev",
    "build": "bun --filter './packages/*' build && bun --filter './apps/*' build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun --filter '*' test",
    "test:e2e": "bun --filter '*' test:e2e",
    "typecheck": "bun --filter '*' typecheck",
    "test:perf": "cd apps/app && bunx playwright test --project perf",
    "postinstall": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "typescript": "^5.7.2"
  }
}
